# Supabase (optional). If set, app uses Supabase instead of localStorage.
# For local Supabase Docker: run `npx supabase start`, then copy the API URL and anon key from the output into a .env file (do not commit .env).
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<paste anon key from `npx supabase status`>

# For hosted Supabase:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Backup to online Supabase (optional). Used by scripts/backup-to-remote.js and run-backup-daemon.js ---
# Local Docker (can reuse VITE_* above, or set explicitly):
# SUPABASE_LOCAL_URL=http://127.0.0.1:54321
# SUPABASE_LOCAL_ANON_KEY=<local anon key>
# Online project (backup destination). Use service_role key from Dashboard > Settings > API for full write access.
# SUPABASE_REMOTE_URL=https://your-project.supabase.co
# SUPABASE_REMOTE_SERVICE_ROLE_KEY=<service_role secret from Dashboard>
